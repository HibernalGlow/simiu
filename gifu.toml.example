[output]
# gif | webp | apng | auto
format = "webp"
quality = 85
# webp 编码档位 0-6，越低越快
webp_method = 4
# 每帧时长（毫秒）
duration_ms = 120
# 循环次数，0 为无限
loop = 0

[naming]
# 默认前缀
prefix = "[#dyna]"
# 可用变量: {prefix} {stem} {archive} {parent}
template = "{prefix}{stem}"

[performance]
# 0 自动，建议根据 CPU 调整如 8 / 12
max_workers = 0
